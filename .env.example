# Database (Neon Postgres — create a free project at https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Stripe (https://stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudinary (https://cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Resend (https://resend.com → API Keys)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@lucyevans.com"
# Email address where Lucy receives admin notifications (new client messages, etc.)
ADMIN_NOTIFY_EMAIL="lucy@example.com"

# Twilio SMS (https://twilio.com → Console → Phone Numbers)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1..."

# Vercel Cron secret — used to authenticate the booking-reminders cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Upstash Redis — used for API rate limiting (https://upstash.com → Redis → Create database)
# Then copy REST URL + REST token from the database dashboard
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""
