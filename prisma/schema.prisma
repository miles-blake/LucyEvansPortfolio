generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Photography Shop ───────────────────────────────────────────────

model Photo {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?
  location        String?
  captureDate     DateTime?
  filmStock       String?
  camera          String?
  collectionTag   String?
  tags            String[]
  previewImageUrl String   // watermarked, public
  fullResFileUrl  String   // private, never served directly
  price           Int      // in cents
  isLimitedEdition Boolean @default(false)
  editionSize     Int?
  editionSold     Int      @default(0)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bundles     BundlePhoto[]
  orderItems  OrderItem[]
}

model Bundle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  price       Int      // in cents
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos     BundlePhoto[]
  orderItems OrderItem[]
}

// many-to-many join for Bundle ↔ Photo
model BundlePhoto {
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  bundleId String
  photo    Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId  String

  @@id([bundleId, photoId])
}

model ServicePackage {
  id             String   @id @default(cuid())
  name           String
  description    String?
  rollsIncluded  Int
  photosIncluded Int
  hoursIncluded  Int?     // hours of coverage included
  basePrice      Int      // in cents
  eventTypes     String[] // e.g. ["wedding", "portrait", "event", "elopement"]
  // Add-on pricing stored as JSON: { extraRollPrice, rushDeliveryPrice, secondShooterPrice }
  addOnPricing   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id              String        @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  eventDate       DateTime
  eventType       String
  packageId       String
  package         ServicePackage @relation(fields: [packageId], references: [id])
  addOns          Json?         // selected add-ons and their prices
  message               String?  // initial message from customer (legacy)
  questionnaireAnswers  Json?    // structured pre-shoot questionnaire answers
  adminNotes            String?  // internal notes, admin-only
  communicationPreference String @default("email") // "email" | "sms"
  status          BookingStatus @default(INQUIRY)
  depositAmount   Int           // in cents
  depositPaid     Boolean       @default(false)
  totalPrice      Int           // in cents
  stripeSessionId String?
  reminderSent7Day Boolean      @default(false)
  reminderSent2Day Boolean      @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  portalToken      ClientPortalToken?
  messages         BookingMessage[]
  deliveredAssets  DeliveredAsset[]
  contract         BookingContract?
}

enum BookingStatus {
  INQUIRY
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── Orders & Digital Delivery ──────────────────────────────────────

model Order {
  id                    String      @id @default(cuid())
  customerEmail         String
  customerName          String      @default("")
  customerPhone         String?
  totalAmount           Int         // in cents
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(PENDING)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  items OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photoId       String?
  photo         Photo?   @relation(fields: [photoId], references: [id])
  bundleId      String?
  bundle        Bundle?  @relation(fields: [bundleId], references: [id])
  price         Int      // in cents, snapshot at time of purchase
  signedDownloadUrl String?
  downloadCount Int      @default(0)
  downloadLimit Int      @default(5)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
}

// ─── Marketing Portfolio ─────────────────────────────────────────────

model PortfolioPiece {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  brandName         String
  role              String?
  description       String?
  deliverables      String?
  metrics           String?  // free text: views/engagement/reach
  videoUrls         String[] // self-hosted Cloudinary URLs
  originalPostUrls  String[] // links back to TikTok/Instagram originals
  coverImageUrl     String?
  tags              String[]
  dateCompleted     DateTime?
  testimonialQuote  String?
  testimonialAuthor String?
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Newsletter ───────────────────────────────────────────────────────

model Subscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  subscribedAt     DateTime @default(now())
  source           String?  // "footer", "homepage", etc.
  confirmed        Boolean  @default(true)
  unsubscribeToken String?  @unique @default(cuid())
}

// ─── Inquiries ────────────────────────────────────────────────────────

model Inquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  subject     String
  message     String
  status      InquiryStatus @default(NEW)
  adminNotes  String?
  repliedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
}

// ─── Newsletter History ───────────────────────────────────────────────

model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  body           String
  sentAt         DateTime?
  recipientCount Int?
  createdAt      DateTime  @default(now())
}

// ─── Invoices ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique // e.g. INV-2026-001
  type           InvoiceType
  bookingId      String?
  orderId        String?
  customerName   String
  customerEmail  String
  customerPhone  String?
  lineItems      Json          // [{ description: string, amount: number }]
  subtotal       Int           // cents
  depositPaid    Int           @default(0) // cents already paid
  amountDue      Int           // cents remaining
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum InvoiceType {
  BOOKING
  ORDER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

// ─── Client Portal ───────────────────────────────────────────────────

model ClientPortalToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Delivery Gallery ────────────────────────────────────────────────

model DeliveredAsset {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String
  url       String
  publicId  String
  createdAt DateTime @default(now())
}

// ─── Contracts ───────────────────────────────────────────────────────

model BookingContract {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  booking    Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  pdfUrl     String
  signedAt   DateTime?
  signedName String?
  createdAt  DateTime  @default(now())
}

// ─── Availability ────────────────────────────────────────────────────

model BlackoutDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
}

// ─── Messaging ────────────────────────────────────────────────────────

model BookingMessage {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderRole   String   // "admin" | "client"
  body         String
  readByAdmin  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ─── Client Accounts ─────────────────────────────────────────────────

model Client {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  hashedPassword    String
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?   @unique @default(cuid())
  createdAt         DateTime  @default(now())
}

// ─── Discount Codes ──────────────────────────────────────────────────

model DiscountCode {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String    // "fixed" | "percent"
  amount     Int       // cents (fixed) or 1-100 (percent)
  active     Boolean   @default(true)
  usageLimit Int?
  usageCount Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

// ─── Site Settings ────────────────────────────────────────────────────

model SiteSettings {
  id                String @id @default("main")
  watermarkText     String @default("© Lucy Evans")
  watermarkOpacity  Int    @default(60)
  watermarkPosition String @default("south_east")
  watermarkFontSize Int    @default(24)
}

// ─── Audit Log ────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "booking.status_changed", "booking.deleted", "invoice.marked_paid"
  targetId   String?  // ID of the affected record
  meta       Json?    // extra context (old status → new status, etc.)
  createdAt  DateTime @default(now())
}

// ─── Client Reviews ──────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  bookingId   String?
  clientName  String
  clientEmail String
  rating      Int      // 1–5
  body        String
  approved    Boolean  @default(false)
  token       String   @unique @default(cuid())
  createdAt   DateTime @default(now())
}

// ─── Admin ────────────────────────────────────────────────────────────

model AdminUser {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  isTestClient   Boolean  @default(false)
  createdAt      DateTime @default(now())
}
